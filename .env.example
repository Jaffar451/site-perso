# ==========================================
# 🗄️ CONFIGURATION DE LA BASE DE DONNÉES
# ==========================================
DB_HOST=localhost
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=justice_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ✅ URL DE CONNEXION POUR PRISMA (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/justice_db?schema=public"

# ✅ Paramètres critiques
DB_ALTER=true
DB_LOGGING=true

# ==========================================
# 🔐 SÉCURITÉ & AUTHENTIFICATION (JWT)
# ==========================================
# Générer des secrets forts, ex: openssl rand -hex 64
JWT_SECRET=changeme
REFRESH_SECRET=changeme

JWT_EXPIRES_IN=7d
REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=10
CORS_ORIGIN=*

# ==========================================
# 📂 GESTION DES FICHIERS
# ==========================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ==========================================
# 🚀 CONFIGURATION DU SERVEUR
# ==========================================
PORT=4000
NODE_ENV=development
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
